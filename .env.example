PROJECT_NAME=BizzInt
API_V1_STR=/api/v1

POSTGRES_SERVER=localhost
POSTGRES_PORT=5434
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=bizzint

# Optional: If DATABASE_URL is provided, it will be used directly.
# If omitted, it will be assembled from the POSTGRES_* variables above.
# DATABASE_URL=postgresql+asyncpg://postgres:your_password_here@localhost:5434/bizzint
# TEST_DATABASE_URL=postgresql+asyncpg://postgres:your_test_password_here@localhost:5435/bizzint_test

GEMINI_API_KEY=your_gemini_api_key_here

SECRET_KEY=your_secret_key_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

BASE_URL=http://localhost:8000